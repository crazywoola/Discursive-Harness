#!/usr/bin/env python3
"""
jurgen — a discursive (Habermasian) multi-agent deliberation harness.

Named for Jürgen Habermas. This is NOT a reflexive self-critique loop; it stages
a *dialogue* among opposed party-agents whose legitimacy lives in reasons
exchanged under power-free conditions, recorded in a reopenable reason ledger.

The "fundamental agent" is Claude Code itself: every party / stakeholder-finder
is a headless `claude -p` invocation. The REFEREE is deliberately NOT an agent —
it is deterministic, content-blind code (see plan §5). That separation is the
whole game.

Usage:
    ./jurgen "Should we ship feature X before the audit?"
    ./jurgen deliberate "<task>" --model claude-sonnet-4-6 --max-rounds 3
    ./jurgen "<task>" --json > ledger.json
"""

import argparse
import concurrent.futures
import json
import re
import subprocess
import sys
import textwrap
import time
