OUTCOME_BLURB = {
    RATIONAL_CONSENSUS: ("RATIONAL CONSENSUS", C.GRN,
        "One thesis survived with no open challenge."),
    UNDERDETERMINED: ("UNDERDETERMINED", C.YEL,
        "Multiple theses survived equally — selection handed to humans."),
    REASONABLE_DISAGREEMENT: ("REASONABLE DISAGREEMENT", C.MAG,
        "Open challenges persist — a map of WHY consensus is impossible."),
}

def print_ledger(ledger):
    name, color, blurb = OUTCOME_BLURB.get(
        ledger["outcome_type"], (ledger["outcome_type"], C.YEL, ""))
    bar = "═" * 70
    print()
    print(c(bar, color))
    print(c(f"  VERDICT: {name}", C.B + color))
    print(c(f"  {blurb}", C.DIM))
    print(c(bar, color))
    print()
    print(c("TASK", C.B) + f"  {ledger['task']}")
    print()

    if ledger.get("summary"):
        print(c("SUMMARY", C.B))
        for line in textwrap.wrap(ledger["summary"], 68):
            print("  " + line)
        print()

    print(c("SURVIVING CLAIMS", C.B + C.GRN))
    if not ledger["surviving_claims"]:
        print(c("  (none — no thesis is currently defended)", C.DIM))
    for cl in ledger["surviving_claims"]:
        print(f"  • [{cl['id']}] {c(cl['claim'], C.GRN)}")
        for r in cl["reasons"]:
            print(c(f"      ↳ ({r['groundType']}) {r['content']}", C.DIM))
    print()

    print(c("DEFEATED ALTERNATIVES", C.B + C.RED) + c("  (reopenable)", C.DIM))
    if not ledger["defeated_alternatives"]:
        print(c("  (none)", C.DIM))
    for d in ledger["defeated_alternatives"]:
        print(f"  ✗ [{d['claim_id']}] {d['claim']}")
        print(c(f"      killed_by {d['killed_by']}: {d['why']}", C.DIM))
    print()

    print(c("UNRESOLVED CHALLENGES", C.B + C.MAG))
    if not ledger["unresolved_challenges"]:
        print(c("  (none — graph closed)", C.DIM))
    for u in ledger["unresolved_challenges"]:
        print(f"  ? [{u['id']}] {u['type']} → {u['target']}")
        print(c(f"      {u['content']}", C.DIM))
    print()

    if ledger.get("excluded_then_included"):
        print(c("EXCLUDED-THEN-INCLUDED (de-occlusion)", C.B + C.CYN))
        for p in ledger["excluded_then_included"]:
            print(f"  + {p['name']} — {p['stance']}")
        print()

    if ledger.get("decision_point_for_human"):
        print(c("⟶ DECISION POINT FOR HUMAN", C.B + C.YEL))
        for line in textwrap.wrap(ledger["decision_point_for_human"], 68):
            print(c("  " + line, C.YEL))
        print()

    m = ledger.get("_meta", {})
    print(c(f"[{m.get('model','?')} · {m.get('elapsed_sec','?')}s]", C.DIM))


# ──────────────────────────────────────────────────────────────────────────────
# CLI
# ──────────────────────────────────────────────────────────────────────────────
def main():
    ap = argparse.ArgumentParser(
        prog="jurgen",
        description="Discursive (Habermasian) multi-agent deliberation harness. "
                    "Party-agents are headless Claude Code invocations; the "
                    "referee is deterministic code.",
    )
    ap.add_argument("task", nargs="?", help="the decision/question to deliberate")
    ap.add_argument("cmd_or_task", nargs="?", help=argparse.SUPPRESS)
    ap.add_argument("--model", default="claude-sonnet-4-6",
                    help="model for party-agents (default: claude-sonnet-4-6)")
    ap.add_argument("--max-rounds", type=int, default=3,
                    help="max challenge/response rounds (default: 3)")
    ap.add_argument("--stall-rounds", type=int, default=2,
                    help="rounds with no progress → reasonable disagreement (default: 2)")
    ap.add_argument("--max-stakeholders", type=int, default=4,
                    help="cap on seated parties (default: 4)")
    ap.add_argument("--json", action="store_true", help="emit raw ledger JSON only")
    ap.add_argument("--out", help="write ledger JSON to this file")
    ap.add_argument("--quiet", action="store_true", help="suppress phase logging")
    args = ap.parse_args()

    # allow `jurgen deliberate "<task>"` as well as `jurgen "<task>"`
    task = args.task
    if task == "deliberate" and args.cmd_or_task:
        task = args.cmd_or_task
    if not task:
        ap.print_help()
        sys.exit(1)

    quiet = args.quiet or args.json
    try:
        graph, ledger = deliberate(
            task, args.model, args.max_rounds, args.stall_rounds,
            args.max_stakeholders, quiet)
    except AgentError as e:
        print(c(f"jurgen: agent failure: {e}", C.RED), file=sys.stderr)
        sys.exit(2)
    except KeyboardInterrupt:
        print(c("\njurgen: interrupted", C.RED), file=sys.stderr)
        sys.exit(130)

    if args.out:
        with open(args.out, "w") as f:
            json.dump(ledger, f, indent=2)
        log(f"ledger written to {args.out}", quiet)

    if args.json:
        print(json.dumps(ledger, indent=2))
    else:
        print_ledger(ledger)


if __name__ == "__main__":
    main()
